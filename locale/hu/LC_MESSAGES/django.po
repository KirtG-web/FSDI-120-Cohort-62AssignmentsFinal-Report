msgstr "Magyar ételek"

#: .\main\templates\food.html:17 .\main\templates\food.html:19
msgid "Gulyás (Goulash)"
msgstr ""

#: .\main\templates\food.html:21
msgid "A hearty stew made with beef, vegetables, and vibrant paprika."
msgstr "Laktató ragu marhahússal, zöldségekkel és élénk paprikával."

#: .\main\templates\food.html:26 .\main\templates\food.html:27
msgid "Pörkölt"
msgstr "Pörkölt"

#: .\main\templates\food.html:29
msgid "A savory, thick stew slow-cooked with onions and roasted meats."
msgstr "Ízletes, sűrű ragu, amelyet hagymával és sült húsokkal lassan főznek."

#: .\main\templates\food.html:34 .\main\templates\food.html:35
msgid "Lángos"
msgstr "Lángos"

#: .\main\templates\food.html:37
msgid "Fried dough topped with garlic, sour cream, and cheese."
msgstr "Sült tészta fokhagymával, tejföllel és sajttal."

#: .\main\templates\food.html:42 .\main\templates\food.html:43
msgid "Csirke Paprikás"
msgstr "Paprikás csirke"

#: .\main\templates\food.html:45
msgid "Creamy chicken simmered in rich paprika sauce."
msgstr "Krémes csirke gazdag paprikás szószban főzve."

#: .\main\templates\gallery.html:11 .\main\templates\gallery.html:12
msgid "Traditional Attire"
msgstr "Hagyományos viselet"

#: .\main\templates\gallery.html:16 .\main\templates\gallery.html:17
msgid "Folk Dance Costumes"
msgstr "Néptánc viseletek"

#: .\main\templates\gallery.html:21 .\main\templates\gallery.html:22
