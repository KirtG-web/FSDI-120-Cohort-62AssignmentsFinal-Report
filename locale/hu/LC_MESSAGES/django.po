msgid ""
"A, Á, B, C, Cs, D, Dz, Dzs, E, É, F, G, Gy, H, I, Í, J, K, L, Ly, M, N, Ny, "
"O, Ó, Ö, Ő, P, R, S, Sz, T, Ty, U, Ú, Ü, Ű, V, Z, Zs"
msgstr ""
"A, Á, B, C, Cs, D, Dz, Dzs, E, É, F, G, Gy, H, I, Í, J, K, L, Ly, M, N, Ny, "
"O, Ó, Ö, Ő, P, R, S, Sz, T, Ty, U, Ú, Ü, Ű, V, Z, Zs"

#: .\main\templates\language.html:19
msgid "Vowels: á, é, í, ó, ö, ő, ú, ü, ű"
msgstr "Magánhangzók: á, é, í, ó, ö, ő, ú, ü, ű"

#: .\main\templates\language.html:25
msgid "Numbers (0–10)"
msgstr "Számok (0–10)"

#: .\main\templates\language.html:27
msgid "0: nulla • 1: egy • 2: kettő • 3: három • 4: négy • 5: öt"
msgstr "0: nulla • 1: egy • 2: kettő • 3: három • 4: négy • 5: öt"

#: .\main\templates\language.html:30
